# ===========================================
# Client env — copy to client/.env
# cp client/env/.env.sample client/.env
# Vite exposes only vars prefixed with VITE_
# ===========================================

# API base URL — always from env (no hardcode). Change when API runs on another port.
# Same origin (proxy): /api  → requests go to this app then proxied by VITE_API_PROXY_TARGET
# API on 5173 (other project): http://localhost:5173/api
# Production: your API origin, e.g. https://api.example.com
VITE_API_BASE_URL=/api

# Proxy target (dev only): where /api is forwarded. Default 3000; set to 5173 if API runs on 5173.
# VITE_API_PROXY_TARGET=http://localhost:3000
# VITE_API_PROXY_TARGET=http://localhost:5173

# Optional: public app title
# VITE_APP_TITLE=ElsnerQwilr

# Optional: stronger URL obfuscation (?folder=, ?id=, /proposals/:id/edit). Must match server PUBLIC_QUERY_OBFUSCATE_KEY.
# Without this, URLs still use b1.* Base64 tokens (not human-readable names/hex ids).
# VITE_PUBLIC_QUERY_OBFUSCATE_KEY=your-long-random-string
