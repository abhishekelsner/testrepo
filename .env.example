# ===========================================
# Shared dev cluster — same values for all 6
# Copy this file to .env and fill in the shared URIs.
# Never commit .env to Git.
# ===========================================

# MongoDB (from MongoDB Atlas — one cluster for the team)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/elsnerqwilr?retryWrites=true&w=majority

# Redis (optional — from Upstash or Redis Cloud)
REDIS_URL=redis://default:<password>@<host>:<port>

# ===========================================
# App config (can differ per developer)
# ===========================================
NODE_ENV=development
API_PORT=3000
WEB_ORIGIN=http://localhost:5173

# JWT (use same secret for dev so tokens work across the team, or generate one and share)
JWT_SECRET=your-shared-dev-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-shared-dev-refresh-secret-min-32-chars

# Optional: Zoho Sign, Stripe (for dev; use test keys)
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# STRIPE_SECRET_KEY=sk_test_
# STRIPE_WEBHOOK_SECRET=whsec_
