# ===========================================
# Server env — copy to server/.env or repo root .env
# cp server/env/.env.sample server/.env
# ===========================================

NODE_ENV=development
API_PORT=3000
WEB_ORIGIN=http://localhost:5173

# MongoDB (shared cluster for the team)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/elsnerqwilr?retryWrites=true&w=majority

# Redis (optional)
# REDIS_URL=redis://default:<password>@<host>:<port>

# JWT
JWT_SECRET=your-shared-dev-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-shared-dev-refresh-secret-min-32-chars

# SMTP (for verification and forgot-password emails)
# If not set, emails are not sent (dev: verifyToken/reset link in response or logs)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=noreply@elsnerqwilr.com

# Optional: Zoho Sign, Stripe
# ZOHO_CLIENT_ID=
# ZOHO_CLIENT_SECRET=
# Stripe (subscription billing) — create 2 Products in Stripe Dashboard with recurring monthly prices, then paste IDs:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_SINGLE=price_...   (Single plan monthly price)
# STRIPE_PRICE_TEAM=price_...     (Team plan monthly price)
# CLIENT_URL=http://localhost:5173   (for Stripe checkout success/cancel redirects)

# Same value as client VITE_PUBLIC_QUERY_OBFUSCATE_KEY — for opaque ?id= links in notification emails
# PUBLIC_QUERY_OBFUSCATE_KEY=
